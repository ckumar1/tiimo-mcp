{
  "name": "tiimo-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for Tiimo (ADHD planner) — read/update todo lists, tasks, and calendar activities via Tiimo's private API. Personal-use, single-account.",
  "bin": {
    "tiimo-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}
